---
import { getCollection } from 'astro:content'
import Header from '../components/Header.astro'
import Sidebar from '../components/Sidebar.astro'
import SiteLayout from '../layouts/SiteLayout.astro'
import { groupPages, sortPages } from '../lib/pages'

const pages = (await getCollection('pages')).sort(sortPages)
const groups = groupPages(pages)
const firstDoc = pages.find((page) => !page.data.isReadme) ?? pages[0]
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const withBase = (path: string) => `${base}${path}`
const chapterArt = new Map([
  [
    '1. Agentic工作流简介 Introduction to Agentic Workflows',
    { src: '/chapter-art/workflows.webp', alt: 'Agentic workflow diagram on a dark study desk' },
  ],
  [
    '2. 反思设计模式 Reflection Design Pattern',
    { src: '/chapter-art/reflection.webp', alt: 'AI assistant reviewing its own output in a mirror-like screen' },
  ],
  [
    '3. 工具使用 Tool Use',
    { src: '/chapter-art/tools.webp', alt: 'AI agent connected to multiple digital tool modules' },
  ],
  [
    '4. 构建Agentic AI的实用技巧 Practical Tips for Building Agentic AI',
    { src: '/chapter-art/practical.webp', alt: 'Engineering dashboard for evaluating and optimizing agentic AI systems' },
  ],
  [
    '5. 高度自治智能体的模式 Patterns for Highly Autonomous Agents',
    { src: '/chapter-art/autonomous.webp', alt: 'Autonomous AI agents collaborating around a central roadmap' },
  ],
])
---

<SiteLayout title="Agentic AI 中文学习博客">
  <Header />
  <div class="app-shell">
    <Sidebar groups={groups} />
    <main class="home-main">
      <section class="home-hero">
        <p class="eyebrow">Datawhale Course Notes</p>
        <h1>Agentic AI 中文学习博客</h1>
        <p>基于原始 Markdown 内容生成的 Astro 静态课程站，左侧按章节组织目录，右侧文章页保留本页多级标题导航。</p>
        <div class="home-hero__actions">
          <a class="button-primary" href={withBase(`/docs/${firstDoc.data.slug}/`)}>开始阅读</a>
          <a class="button-secondary" href={withBase('/docs/home/')}>查看项目介绍</a>
        </div>
      </section>

      <section class="section-grid" aria-label="章节目录">
        {groups.filter((group) => group.section !== '概览').map((group) => {
          const art = chapterArt.get(group.section)
          return (
            <a class="section-card" href={withBase(`/docs/${group.items[0].data.slug}/`)}>
              <span class="section-card__index">{String(group.items[0].data.sectionOrder).padStart(2, '0')}</span>
              <h2>{group.section}</h2>
              {art && (
                <figure class="section-card__art">
                  <img src={withBase(art.src)} alt={art.alt} loading="lazy" decoding="async" />
                </figure>
              )}
              <span class="section-card__action">进入章节</span>
            </a>
          )
        })}
      </section>
    </main>
  </div>
</SiteLayout>
