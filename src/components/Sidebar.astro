---
import type { PageEntry } from '../lib/pages'

interface Props {
  groups: Array<{ section: string; items: PageEntry[] }>
  currentSlug?: string
}

const { groups, currentSlug = '' } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const withBase = (path: string) => `${base}${path}`
---

<button class="sidebar-toggle" type="button" aria-controls="course-sidebar" aria-expanded="true" aria-label="收起课程目录" title="收起/展开课程目录">
  <span aria-hidden="true">‹</span>
</button>

<aside id="course-sidebar" class="sidebar" aria-label="课程目录">
  <div class="sidebar__title">课程目录</div>
  <nav class="sidebar__nav">
    {groups.map((group) => (
      <details class="sidebar__group" open>
        <summary>{group.section}</summary>
        <ol>
          {group.items.map((page) => (
            <li>
              <a class:list={['sidebar__link', page.data.slug === currentSlug && 'is-active']} href={withBase(`/docs/${page.data.slug}/`)}>
                {page.data.navTitle}
              </a>
            </li>
          ))}
        </ol>
      </details>
    ))}
  </nav>
</aside>

<script>
  const sidebarToggle = document.querySelector<HTMLButtonElement>('.sidebar-toggle')
  const root = document.documentElement
  const storageKey = 'agentic-sidebar-collapsed'

  const setSidebarState = (collapsed: boolean) => {
    root.classList.toggle('is-sidebar-collapsed', collapsed)
    sidebarToggle?.setAttribute('aria-expanded', String(!collapsed))
    sidebarToggle?.setAttribute('aria-label', collapsed ? '展开课程目录' : '收起课程目录')
    sidebarToggle?.setAttribute('title', collapsed ? '展开课程目录' : '收起课程目录')
    const glyph = sidebarToggle?.querySelector('span')
    if (glyph) glyph.textContent = collapsed ? '›' : '‹'
    try {
      localStorage.setItem(storageKey, String(collapsed))
    } catch {}
  }

  setSidebarState(root.classList.contains('is-sidebar-collapsed'))
  sidebarToggle?.addEventListener('click', () => {
    setSidebarState(!root.classList.contains('is-sidebar-collapsed'))
  })
</script>
